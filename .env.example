# Copy to .env and adjust. Workshop default: no paid LLM API keys required.

# Semicolon-separated list of repo-relative or absolute directories where code_modify may write
# when using legacy ``repo_root`` (local path). Ignored when ``repo_url`` is used (clones go under .clones/).
SEO_AGENT_REPO_ALLOWLIST=sample-site
# Example legacy multi-root: SEO_AGENT_REPO_ALLOWLIST=sample-site;frontend

# Clone directory for ``repo_url`` apply flow (relative to seo-agent/ when not absolute). One folder per run id.
SEO_AGENT_CLONE_ROOT=.clones

# Optional: override git subprocess timeouts (seconds).
# SEO_AGENT_GIT_CLONE_TIMEOUT_SEC=600
# SEO_AGENT_GIT_FETCH_TIMEOUT_SEC=300

# Experimental: replace first matching quoted internal broken ``href="/path"`` with ``href="/"`` during code_modify.
# Off by default; only set in trusted repos. Broken-link issues still get ``file_hint`` resolution without this flag.
# SEO_AGENT_FIX_BROKEN_LINKS=1

# After a successful local commit on ``test`` (repo_url flow), run ``git push -u origin test`` (default: off).
# Requires push credentials for the clone (SSH agent, credential manager, or token in URL).
SEO_AGENT_GIT_AUTO_PUSH=1
# SEO_AGENT_GIT_PUSH_TIMEOUT_SEC=300

# Persisted SOP index directory (JSON + embeddings; relative to seo-agent/ when not absolute).
CHROMA_PERSIST_DIR=.chroma_data

# --- OSS LLM (Task 0.6) ---
# Embeddings: sentence-transformers model id (see app/services/llm_provider.py default).
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Ollama for sop_validate chat labels. If unreachable, sop_validate falls back to rules-only.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Set to 1 to skip Ollama and use deterministic rule-based SOP labeling (CI-friendly).
SOP_RULES_ONLY=0
