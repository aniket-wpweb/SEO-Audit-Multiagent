# Copy to .env and adjust.

# Clone directory for repo_url apply flow (one folder per run id).
SEO_AGENT_CLONE_ROOT=.clones

# Branch to create/checkout after clone (default: seo-fixes).
SEO_AGENT_GIT_BRANCH=seo-fixes

# After successful verify, run git push -u origin <branch> (default: off).
# SEO_AGENT_GIT_AUTO_PUSH=1

# --- SEO fix engine ---
# chain = rules first, then OpenAI if no change; rules | openai
SEO_FIX_PROVIDER=chain
SEO_FIX_API_KEY=
SEO_FIX_BASE_URL=https://api.openai.com/v1
SEO_FIX_MODEL=gpt-4o-mini

# Optional: re-crawl after apply (see issues_after_apply in API).
# SEO_AGENT_REAUDIT_AFTER_APPLY=1

# Skip npm/pnpm/yarn build after apply (fixes still written; default: run build when deps exist).
# SEO_AGENT_SKIP_POST_BUILD=1

# SOP labeling: set 1 to skip Ollama (rules-only SOP status).
SOP_RULES_ONLY=1

CHROMA_PERSIST_DIR=.chroma_data
EMBEDDING_MODEL=all-MiniLM-L6-v2
